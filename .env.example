# Copy this file to .env and fill in your values

# ── LLM Providers ─────────────────────────────────────────────────────────────

# OpenAI — required (used for embeddings; also default agent LLM)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic — optional, used when AGENT_LLM=claude
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── LLM Routing ───────────────────────────────────────────────────────────────

# Agent LLM: "openai" (default) | "claude"
AGENT_LLM=openai

# OpenAI model for agent (default: gpt-4o)
OPENAI_MODEL=gpt-5.4

# Judge model for DeepEval evaluation metrics (default: gpt-4o)
EVAL_JUDGE_MODEL=gpt-5.4

# Anthropic model for agent (default: claude-opus-4-6)
ANTHROPIC_MODEL=claude-opus-4-6

# Ollama model for summarization (default: llama3.2)
# Install Ollama: https://ollama.com → then: ollama pull llama3.2
# If Ollama is not running, falls back to gpt-4o-mini automatically.
OLLAMA_MODEL=llama3.2

# ── Tracing (LangSmith) ───────────────────────────────────────────────────────
# LangSmith auto-traces all LangChain/LangGraph calls — no code changes needed.
# Sign up at: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=ai-paper-explorer
