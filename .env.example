# Copy this file to .env and fill in your values

# ── LLM Providers ─────────────────────────────────────────────────────────────

# OpenAI — required (used for embeddings; also default agent LLM)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic — optional, used when AGENT_LLM=claude
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── LLM Routing ───────────────────────────────────────────────────────────────

# Agent LLM: "openai" (default) | "claude"
AGENT_LLM=openai

# OpenAI model for agent (default: gpt-4o)
OPENAI_MODEL=gpt-5.4

# ── Eval Judge (DeepEval) ─────────────────────────────────────────────────────
# Which judge to use for DeepEval metrics:
#   "prometheus"  → Prometheus 2 via Ollama (free, local, best for iteration)
#   "claude"      → claude-opus-4-6 via Anthropic (cross-provider, use for final eval)
#   "openai"      → EVAL_JUDGE_MODEL string below (default when no API keys are set)
# Auto-selects "claude" if ANTHROPIC_API_KEY is set, else "openai"
EVAL_JUDGE=prometheus

# Prometheus 2 Ollama model tag (used when EVAL_JUDGE=prometheus)
# One-time setup: ollama pull vicgalle/prometheus-7b-v2.0   (~4.4 GB)
PROMETHEUS_MODEL=vicgalle/prometheus-7b-v2.0

# OpenAI fallback judge model (used when EVAL_JUDGE=openai)
EVAL_JUDGE_MODEL=gpt-4o

# Anthropic judge model (used when EVAL_JUDGE=claude)
EVAL_JUDGE_MODEL_CLAUDE=claude-opus-4-6

# Anthropic model for agent (default: claude-opus-4-6)
ANTHROPIC_MODEL=claude-opus-4-6

# Ollama model for summarization (default: llama3.2)
# Install Ollama: https://ollama.com → then: ollama pull llama3.2
# If Ollama is not running, falls back to gpt-4o-mini automatically.
OLLAMA_MODEL=llama3.2

# ── Tracing (LangSmith) ───────────────────────────────────────────────────────
# LangSmith auto-traces all LangChain/LangGraph calls (set in main.py).
# Sign up at: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
# Project name is set via os.environ.setdefault in main.py — override here if needed
LANGCHAIN_PROJECT=arxiv-ai-research-tracker
